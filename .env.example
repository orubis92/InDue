# Copia questo file in ".env" e inserisci i valori dal tuo progetto Supabase
# (Dashboard -> Project Settings -> API)
VITE_SUPABASE_URL=https://iltuoprogetto.supabase.co
VITE_SUPABASE_ANON_KEY=la-tua-anon-key

# Chiave PUBBLICA per le notifiche push (vedi AGGIORNAMENTO-V2.md, passo 3).
# Se la lasci vuota l'app funziona lo stesso, solo senza notifiche.
VITE_VAPID_PUBLIC_KEY=
